# ============================================================
# Resume Builder Service - Environment Variables Example
# Copy this file to .env.local and fill in the values
# ============================================================

# Node environment
NODE_ENV=development

# Database (optional - only required if using Prisma/database features)
# DATABASE_URL="postgresql://user:password@localhost:5432/resume_builder"

# Next.js public URL (used for absolute URLs in production)
# NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Analytics (optional - Vercel Analytics is enabled via @vercel/analytics package)
# NEXT_PUBLIC_ANALYTICS_ID=""
